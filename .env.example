PROJECT_NAME="Manga Reader API"
DEBUG=False

# Postgres (обязательно)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=manga_reader

# Redis (опционально — без него API работает, кэш отключается)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
CACHE_TTL_SECONDS=300
POPULAR_TTL_SECONDS=900

# JWT (обязательно, минимум 32 символа)
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Можно оставить пустыми — соберутся из полей выше
DATABASE_URL=
REDIS_URL=
